<Window x:Class="WinLens.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="WinLens"
        Width="1" Height="1"
        WindowStyle="None"
        ShowInTaskbar="False"
        Visibility="Hidden"
        AllowsTransparency="True"
        Background="Transparent">
    <Grid>
        <tb:TaskbarIcon x:Name="Tray"
                        ToolTipText="WinLens — screen translator"
                        Visibility="Visible"
                        TrayMouseDoubleClick="OnTrayDoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Translate now" Click="OnTranslateNow"/>
                    <MenuItem Header="Open WinLens" Click="OnOpenSettings"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="OnExit"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>
    </Grid>
</Window>
