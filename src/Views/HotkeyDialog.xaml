<Window x:Class="WinLens.Views.HotkeyDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinLens — Set hotkey"
        Width="380" Height="180"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        FontFamily="Segoe UI"
        Background="#FAFAFA">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Press the key combination you want to use, then click Save."
                   TextWrapping="Wrap"/>

        <Border Grid.Row="1" Margin="0,12,0,12" Padding="12,8"
                Background="White" BorderBrush="#CCC" BorderThickness="1" CornerRadius="4"
                Focusable="True"
                KeyDown="OnKeyDown"
                PreviewKeyDown="OnPreviewKeyDown">
            <TextBlock x:Name="HotkeyDisplay"
                       FontSize="16" FontWeight="SemiBold"
                       Text="(focus this box and press a key)"/>
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel" Width="80" Margin="0,0,8,0" IsCancel="True"/>
            <Button x:Name="SaveButton" Content="Save" Width="80"
                    IsDefault="True" IsEnabled="False" Click="OnSave"/>
        </StackPanel>
    </Grid>
</Window>
